---
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');

const skills = [
  'JavaScript',
  'TypeScript',
  'React',
  'Vue',
  'Astro',
  'Node.js',
  'Python',
  'Go',
];

const socialLinks = [
  {
    name: 'GitHub',
    href: 'https://github.com/liuzhne',
    icon: '<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>',
  },
  {
    name: 'Twitter',
    href: 'https://twitter.com',
    icon: '<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>',
  },
  {
    name: 'Email',
    href: 'mailto:1044307322@qq.com',
    icon: '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>',
  },
];
---

<section class="py-20 md:py-32 px-4">
  <div class="max-w-4xl mx-auto text-center">
    <!-- Avatar -->
    <div class="mb-8">
      <div class="w-24 h-24 md:w-32 md:h-32 mx-auto rounded-full bg-gradient-to-br from-blue-500 to-purple-600 flex items-center justify-center text-white text-3xl md:text-4xl font-bold">
        L
      </div>
    </div>

    <!-- Name & Title -->
    <h1 class="text-4xl md:text-6xl font-bold text-gray-900 dark:text-white mb-4">
      liuzhne
    </h1>
    <p class="text-xl md:text-2xl text-gray-600 dark:text-gray-300 mb-6">
      全栈开发者 · 技术博主 · 开源爱好者
    </p>

    <!-- Bio -->
    <p class="text-lg text-gray-600 dark:text-gray-400 max-w-2xl mx-auto mb-8">
      热爱编程，专注于 Web 开发和云原生技术。在这里分享我的技术心得、学习笔记和项目经验。
    </p>

    <!-- Skills -->
    <div class="flex flex-wrap justify-center gap-2 mb-10">
      {skills.map((skill) => (
        <span class="px-4 py-2 bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 rounded-full text-sm font-medium">
          {skill}
        </span>
      ))}
    </div>

    <!-- CTA Buttons -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-10">
      <a
        href={`${baseUrl}/blog/`}
        class="px-8 py-3 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg transition-colors"
      >
        阅读博客
      </a>
      <a
        href={`${baseUrl}/about/`}
        class="px-8 py-3 border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-800 font-medium rounded-lg transition-colors"
      >
        了解更多
      </a>
    </div>

    <!-- Social Links -->
    <div class="flex items-center justify-center gap-4">
      {socialLinks.map((link) => (
        <a
          href={link.href}
          target="_blank"
          rel="noopener noreferrer"
          class="p-2 text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-800 rounded-lg transition-colors"
          aria-label={link.name}
          set:html={link.icon}
        />
      ))}
    </div>
  </div>
</section>
